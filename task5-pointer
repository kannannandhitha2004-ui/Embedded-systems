//15. Difference between pointer types

#include <stdio.h>

int main() {
    int a = 10, b = 20;

    const int *p1 = &a;   // value cannot change
    int *const p2 = &a;   // address cannot change
    const int *const p3 = &a; // value & address cannot change

    printf("%d %d %d", *p1, *p2, *p3);

    return 0;
}

