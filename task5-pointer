//11. memcpy()

#include <stdio.h>

void memcpy(char *d, char *s, int n) {
    for (int i = 0; i < n; i++)
        d[i] = s[i];
}

int main() {
    char s[] = "Hello";
    char d[10];

    memcpy(d, s, 6);
    printf("%s", d);

    return 0;
}

//12.memmove()

#include <stdio.h>

void memmove(char *d, char *s, int n) {
    if (d > s) {
        for (int i = n - 1; i >= 0; i--)
            d[i] = s[i];
    } else {
        for (int i = 0; i < n; i++)
            d[i] = s[i];
    }
}

int main() {
    char str[] = "abcdef";
    memmove(str + 2, str, 4);
    printf("%s", str);

    return 0;
}

