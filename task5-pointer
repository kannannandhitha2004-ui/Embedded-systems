//7. Print all elements of an array using pointer arithmetic


#include <stdio.h>

int main() {
    int a[] = {10, 20, 30, 40, 50};
    int *p = a;

    for (int i = 0; i < 5; i++)
        printf("%d ", *(p + i));

    return 0;
}

//8.sum of all elements in array using pointers


#include <stdio.h>

int main() {
    int a[] = {1, 2, 3, 4, 5};
    int *p = a, sum = 0;

    for (int i = 0; i < 5; i++)
        sum += *(p + i);

    printf("Sum = %d", sum);

    return 0;
}

//9. Calculator using function pointers


#include <stdio.h>

int add(int a, int b) 
{ return a + b; 
    }
int sub(int a, int b) 
{ return a - b; 
    }
int mul(int a, int b) 
{ return a * b; 
    }
int divi(int a, int b) 
{ return a / b; 
    }
