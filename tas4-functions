//11.search ele in array

#include <stdio.h>

int search(int a[],int n,int key)
{
    int i;
    for(i=0;i<n;i++)
        if(a[i]==key)
            return i;
    return -1;
}

int main()
{
    int a[]={10,20,30,40,50};
    printf("%d",search(a,5,30));
}


//12.Recursion

#include <stdio.h>

int sum(int n)
{
    if(n==1)
        return 1;
    return n+sum(n-1);
}

int main()
{
    printf("%d",sum(5));
}


//13. Print 1 to N (Recursion)

#include <stdio.h>

void print(int n)
{
    if(n==0)
        return;
    print(n-1);
    printf("%d ",n);
}

int main()
{
    print(5);
}


//14. Nth Fibonacci (Recursion)

#include <stdio.h>

int fib(int n)
{
    if(n<=1)
        return n;
    return fib(n-1)+fib(n-2);
}

int main()
{
    printf("%d",fib(6));
}


//15. Staircase Problem

#include <stdio.h>

int ways(int n)
{
    if(n==0 || n==1)
        return 1;
    return ways(n-1)+ways(n-2);
}

int main()
{
    printf("%d",ways(4));
}

