//7. Demonstrate errno, perror(), and strerror()
#include <stdio.h>
#include <errno.h>
#include <string.h>

int main() {
    FILE *fp = fopen("abc.txt", "r");

    if (fp == NULL) {
        perror("Error");
        printf("errno = %d\n", errno);
        printf("%s\n", strerror(errno));
    }

    return 0;
}

//8. Set the nth bit
#include <stdio.h>

int setBit(int num, int n) {
    return num | (1 << n);
}

int main() {
    printf("%d", setBit(5, 1));
    return 0;
}

//9. Clear the nth bit
#include <stdio.h>

int clearBit(int num, int n) {
    return num & ~(1 << n);
}

int main() {
    printf("%d", clearBit(7, 1));
    return 0;
}
10. Toggle the nth bit
#include <stdio.h>

int toggleBit(int num, int n) {
    return num ^ (1 << n);
}

int main() {
    printf("%d", toggleBit(5, 0));
    return 0;
}

//11. Check whether the nth bit is set
#include <stdio.h>

int checkBit(int num, int n) {
    return (num & (1 << n));
}

int main() {
    if (checkBit(5, 2))
        printf("Bit is Set");
    else
        printf("Bit is Not Set");

    return 0;
}

//12. Implement your own calloc() using malloc()
#include <stdio.h>
#include <stdlib.h>

void *myCalloc(int n, int size) {
    char *p = (char *)malloc(n * size);

    for (int i = 0; i < n * size; i++)
        p[i] = 0;

    return p;
}

int main() {
    int *a = (int *)myCalloc(5, sizeof(int));

    for (int i = 0; i < 5; i++)
        printf("%d ", a[i]);

    free(a);
    return 0;
}

//13. Allocate memory for a structure using malloc()
#include <stdio.h>
#include <stdlib.h>

struct Student {
    char name[20];
    int age;
};

int main() {
    struct Student *s;

    s = (struct Student *)malloc(sizeof(struct Student));

    strcpy(s->name, "Nandhitha");
    s->age = 21;

    printf("%s %d", s->name, s->age);

    free(s);
    return 0;
}

//14. Linear Search
