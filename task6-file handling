//15.Bubble Sort (Ascending Order)
#include <stdio.h>

int main() {
    int a[] = {5, 2, 8, 1, 3};
    int temp;

    for (int i = 0; i < 5; i++) {
        for (int j = 0; j < 4 - i; j++) {
            if (a[j] > a[j + 1]) {
                temp = a[j];
                a[j] = a[j + 1];
                a[j + 1] = temp;
            }
        }
    }

    for (int i = 0; i < 5; i++)
        printf("%d ", a[i]);

    return 0;
}
